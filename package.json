{
  "name": "loopy",
  "version": "0.1.0",
  "private": true,
  "description": "AI interaction feedback tool — desktop window that blocks AI execution until user responds",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "cursor",
    "mcp",
    "feedback",
    "tauri",
    "vue",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vue-tsc --noEmit && vp build",
    "preview": "vp preview",
    "typecheck": "vue-tsc --noEmit",
    "tauri": "tauri",
    "build:all": "cd mcp-server && npm run build && npm run bundle && cd .. && npx tauri build",
    "release": "node scripts/release.mjs",
    "publish": "node scripts/publish.mjs",
    "setup": "node setup.mjs",
    "version": "bumpp --all --no-push --no-tag --files package.json mcp-server/package.json src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "bumpp": "^10.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vue-tsc": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
